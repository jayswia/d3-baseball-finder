  UTL:{h:71.0, w:182.4}
};

// ── STEP DEFINITIONS ─────────────────────────────────────────────
// Each step: { id, label, question, hint, key, options[], cols, skipFn }
// Values are always plain strings or numbers — no embedded quotes.

var STEPS = [
  {
    id:"position", key:"position", cols:2,
    label:"Step 1 of 6",
    question:"What position do you play?",
    hint:"Pick the one you plan to play in college.",
    options:[
      {val:"C",   icon:"", label:"Catcher",         sub:""},
      {val:"CI",  icon:"", label:"Corner Infield",  sub:"1B or 3B"},
      {val:"MI",  icon:"", label:"Middle Infield",  sub:"2B or SS"},
      {val:"OF",  icon:"", label:"Outfield",        sub:""},
      {val:"P",   icon:"", label:"Pitcher",         sub:""},
      {val:"UTL", icon:"", label:"Multi-position",  sub:"UTL / multiple spots"}
    ]
  },
  {
    id:"style", key:"style", cols:1,
    label:"Step 2 of 6",
    question:null, hint:null,  // set dynamically
    options:null               // set dynamically
  },
  {
    id:"speed", key:"speed", cols:1,
    label:"Step 3 of 6",
    question:"How would you describe your speed on the bases?",
    hint:"Be honest — this shapes how schools match your playing style.",
    skipFn: function(a){ return a.position === "P"; },
    options:[
      {val:"very_fast",        icon:"", label:"Very fast",           sub:"Top of the order, stolen base threat"},
      {val:"average_speed",    icon:"", label:"Average speed",       sub:"Run when I need to, not a liability"},
      {val:"not_a_baserunner", icon:"", label:"Not a base-stealer",  sub:"Power bat, station-to-station"}
    ]
  },
  {
    id:"drive", key:"drive", cols:1,
    label:"Step 4 of 6",
    question:"How far from Naperville are you willing to drive?",
    hint:"NCC is right in Naperville. North Park & Illinois Tech are the farthest at ~40–50 min.",
    options:[
      {val:"15", icon:"", label:"Under 15 minutes",     sub:"NCC, Wheaton, Benedictine"},
      {val:"25", icon:"", label:"Under 25 minutes",     sub:"Adds Elmhurst"},
      {val:"35", icon:"", label:"Under 35 minutes",     sub:"Adds Concordia & Dominican"},
      {val:"60", icon:"", label:"Show all 8 schools",   sub:"Adds Illinois Tech & North Park"}
    ]
  },
  {
    id:"academic", key:"academic", cols:1,
    label:"Step 5 of 6",
    question:"What's your current GPA?",
    hint:"D3 programs range from open-admission to moderately selective. We'll flag your fit on each card.",
    options:[
      {val:"high",     icon:"", label:"3.5 or above",   sub:"Honor roll / high academic standing"},
      {val:"mid",      icon:"", label:"3.0 – 3.4",      sub:"Solid — meets most D3 minimums comfortably"},
      {val:"standard", icon:"", label:"2.5 – 2.9",      sub:"Eligible at most programs"},
      {val:"lower",    icon:"", label:"Below 2.5",       sub:"May need coach support for admission"}
    ]
  },
  {
    id:"culture", key:"culture", cols:1,
    label:"Step 6 of 6",
    question:"What roster culture fits you best?",
    hint:"NCC is the only school with meaningful transfer activity (22% of roster).",
    options:[
      {val:"transfer",  icon:"", label:"Transfer-friendly",  sub:"Players from many different programs"},
      {val:"homegrown", icon:"", label:"Homegrown team",      sub:"Most players committed as freshmen"},
      {val:"any",       icon:"", label:"No preference",       sub:"Culture does not affect my decision"}
    ]
  }
];

// Pitcher style options
var PITCHER_OPTS = {
  question:"What type of pitcher are you?",
  hint:"Select your handedness and approach.",
  options:[
    {val:"lhp_strikeout", icon:"", label:"LHP — strikeout",       sub:"Left-handed, power arm, miss bats"},
    {val:"lhp_contact",   icon:"", label:"LHP — contact/ground ball", sub:"Left-handed, pitch to contact"},
    {val:"rhp_strikeout", icon:"", label:"RHP — strikeout",       sub:"Right-handed, power arm, miss bats"},
    {val:"rhp_contact",   icon:"", label:"RHP — contact/ground ball", sub:"Right-handed, pitch to contact"}
  ]
};

// Hitter style options
var HITTER_OPTS = {
  question:"How do you bat, and what is your hitting style?",
  hint:"We use this to check handedness fit on each roster.",
  options:[
    {val:"L_power",   icon:"", label:"Left-handed, power bat",     sub:""},
    {val:"L_contact", icon:"", label:"Left-handed, contact/speed", sub:""},
    {val:"R_power",   icon:"", label:"Right-handed, power bat",    sub:""},
    {val:"R_contact", icon:"", label:"Right-handed, contact",      sub:""},
    {val:"S_any",     icon:"", label:"Switch hitter",              sub:""}
  ]
};

// ── STATE ────────────────────────────────────────────────────────
var state = { stepIdx: 0, answers: {} };

// ── MATCHING ─────────────────────────────────────────────────────
function buildTags(a) {
  var t = {};
  function add(tag){ t[tag] = true; }

  // Position depth tags
  var posMap = {
    C:  ["catcher-opportunity","crowded-catcher"],
    CI: ["corner-inf-opportunity","crowded-corner-inf"],
    MI: ["middle-inf-opportunity","crowded-middle-inf"],
    OF: ["outfield-opportunity","crowded-outfield"],
    UTL:["small-roster-high-opportunity"]
  };
  var posTags = posMap[a.position] || [];
  for (var i=0; i<posTags.length; i++) add(posTags[i]);

  // Style tags
  var s = a.style || "";
  // Pitcher styles — handedness
  if (s.indexOf("lhp_") === 0) { add("lhp-heavy-staff"); add("balanced-pitching-mix"); }
  if (s.indexOf("rhp_") === 0) { add("rhp-dominant-staff"); add("balanced-pitching-mix"); }
  // Pitcher styles — approach
  if (s === "lhp_strikeout" || s === "rhp_strikeout") { add("strikeout-staff"); add("solid-strikeout-staff"); }
  if (s === "lhp_contact"   || s === "rhp_contact")   { add("elite-pitching"); add("average-pitching"); }
  // Hitter styles
  if (s.indexOf("L_") === 0 || s.indexOf("S_") === 0) add("lefty-hitter-scarce");
  if (s.indexOf("_power") > -1) { add("power-hitting"); add("hitter-friendly-ERA"); }
  if (s.indexOf("_contact") > -1 && s.indexOf("lhp_") !== 0 && s.indexOf("rhp_") !== 0) { add("contact-hitting"); add("patient-lineup"); }

  // Speed tags
  if (a.speed === "very_fast")        { add("speed-first-offense"); add("balanced-speed"); }
  if (a.speed === "average_speed")    { add("balanced-speed"); add("station-to-station"); add("contact-hitting"); }
  if (a.speed === "not_a_baserunner") { add("station-to-station"); add("power-hitting"); }

  // Culture tags
  if (a.culture === "transfer")  add("transfer-heavy-roster");
  if (a.culture === "homegrown") add("homegrown-roster");

  return t;
}

function runMatch(a) {
  var desired = buildTags(a);
  var maxDrive = parseInt(a.drive, 10);
  var out = [];
  for (var i=0; i<SCHOOLS.length; i++) {
    var s = SCHOOLS[i];
    if (s.drive > maxDrive) continue;
    var matched = [];
    for (var j=0; j<s.tags.length; j++) {
      if (desired[s.tags[j]]) matched.push(s.tags[j]);
    }
    out.push({ school: s, score: matched.length, matched: matched });
  }
  out.sort(function(a,b){
    if (b.score !== a.score) return b.score - a.score;
    return a.school.era - b.school.era;
  });
  return out;
}

// ── RENDER HELPERS ───────────────────────────────────────────────
var TAG_LABELS = {
  "speed-first-offense":          "Speed-first offense",
  "balanced-speed":               "Balanced running game",
  "station-to-station":           "Station-to-station offense",
  "power-hitting":                "Power-hitting lineup",
  "contact-hitting":              "Contact-hitting team",
  "developing-offense":           "Developing offense",
  "patient-lineup":               "Patient, walk-heavy lineup",
  "tall-pitching-staff":          "Tall pitching staff (avg 6'2\"+)",
  "above-avg-height-staff":       "Above-avg pitcher height (6'1\")",
  "shorter-pitching-staff":       "Shorter pitching staff",
  "strikeout-staff":              "High-K pitching staff",
  "solid-strikeout-staff":        "Solid strikeout numbers",
  "elite-pitching":               "Elite team ERA (4.32)",
  "average-pitching":             "Average team ERA",
  "hitter-friendly-ERA":          "Hitter-friendly ERA",
  "lhp-heavy-staff":              "LHP-heavy rotation (33%+)",
  "rhp-dominant-staff":           "RHP-dominant staff",
  "balanced-pitching-mix":        "Balanced LHP/RHP mix",
  "lefty-hitter-scarce":          "Few lefty bats on roster",
  "lefty-hitter-rich":            "Lefty-bat-heavy lineup",
  "transfer-heavy-roster":        "Transfer-friendly culture (22%)",
  "homegrown-roster":             "Homegrown roster (0% transfers)",
  "crowded-catcher":              "Crowded at catcher (5+)",
  "catcher-opportunity":          "Catcher opening (2 on roster)",
  "crowded-corner-inf":           "Crowded corner infield",
  "corner-inf-opportunity":       "Corner INF opening",
  "crowded-middle-inf":           "Crowded middle infield",
  "middle-inf-opportunity":       "Middle INF opening",
  "crowded-outfield":             "Crowded outfield (8+)",
  "outfield-opportunity":         "Outfield opening",
  "large-roster":                 "Large roster (45+)",
  "small-roster-high-opportunity":"Small roster, high PT opportunity"
};

function tl(tag) { return TAG_LABELS[tag] || tag; }

function tagCls(tag) {
  if (tag.indexOf("opportunity") > -1 || tag === "lefty-hitter-scarce" ||
      tag === "elite-pitching" || tag === "homegrown-roster" || tag === "transfer-heavy-roster")
    return "tag-opportunity";
  if (tag.indexOf("crowded") > -1 || tag === "hitter-friendly-ERA" || tag === "developing-offense")
    return "tag-caution";
  return "tag-info";
}

function pct(v) {
  if (v === null || v === undefined) return "N/A";
  return Math.round(v * 100) + "%";
}

function inFt(inches) {
  if (inches === null || inches === undefined) return null;
  var ft  = Math.floor(inches / 12);
  var inc = Math.round(inches % 12 * 10) / 10;
  return ft + "'" + (inc % 1 === 0 ? inc.toFixed(0) : inc.toFixed(1)) + '"';
}

// ── STEP LOGIC ───────────────────────────────────────────────────
function getStep() { return STEPS[state.stepIdx]; }

function resolveStep(step) {
  // Inject dynamic options/question for style step
  if (step.id === "style") {
    var src = (state.answers.position === "P") ? PITCHER_OPTS : HITTER_OPTS;
    return { id:step.id, key:step.key, cols:step.cols, label:step.label,
             question:src.question, hint:src.hint, options:src.options };
  }
  return step;
}

function shouldSkip(step) {
  return step.skipFn && step.skipFn(state.answers);
}

function totalVisible() {
  var n = 0;
  for (var i=0; i<STEPS.length; i++) if (!shouldSkip(STEPS[i])) n++;
  return n;
}

function visibleIndex() {
  var n = 0;
  for (var i=0; i<state.stepIdx; i++) if (!shouldSkip(STEPS[i])) n++;
  return n;
}

function advance() {
  state.stepIdx++;
  while (state.stepIdx < STEPS.length && shouldSkip(STEPS[state.stepIdx])) state.stepIdx++;
}

function retreat() {
  state.stepIdx--;
  while (state.stepIdx > 0 && shouldSkip(STEPS[state.stepIdx])) state.stepIdx--;
}

// ── RENDER ───────────────────────────────────────────────────────
function render() {
  if (state.stepIdx >= STEPS.length) { showResults(); return; }

  var rawStep = getStep();
  if (shouldSkip(rawStep)) { advance(); render(); return; }

  var step = resolveStep(rawStep);
  var pct2 = ((visibleIndex() + 1) / (totalVisible() + 1)) * 100;
  document.getElementById("pf").style.width = pct2 + "%";

  var sel = state.answers[step.key];
  var canNext = sel !== undefined && sel !== null;

  var opts = "";
  for (var i=0; i<step.options.length; i++) {
    var o = step.options[i];
    var isSel = (String(sel) === String(o.val));
    var subHtml = o.sub ? "<div class='sublabel'>" + o.sub + "</div>" : "";
    // Use data-key and data-val attributes — no quoting issues in onclick
    opts += "<button class='option-btn" + (isSel ? " selected" : "") + "' " +
            "data-key='" + step.key + "' data-val='" + o.val + "' onclick='pick(this)'>" +
            "<span class='label'>" + o.label + subHtml + "</span></button>";
  }

  var backBtn = state.stepIdx > 0
    ? "<button class='btn btn-back' onclick='goBack()'>&#8592; Back</button>"
    : "";

  var html = "<div class='step-card'>" +
    "<div class='step-label'>" + step.label + "</div>" +
    "<div class='step-question'>" + step.question + "</div>" +
    "<div class='step-hint'>" + (step.hint || "") + "</div>" +
    "<div class='options" + (step.cols === 2 ? " two-col" : "") + "'>" + opts + "</div>" +
    "<div class='nav-row'>" + backBtn +
    "<button class='btn btn-next' onclick='goNext()' " + (canNext ? "" : "disabled") + ">" +
    (state.stepIdx < STEPS.length - 1 ? "Continue &#8594;" : "Find My Schools &#8594;") +
    "</button></div></div>";

  document.getElementById("app").innerHTML = html;
}

function pick(btn) {
  var key = btn.getAttribute("data-key");
  var val = btn.getAttribute("data-val");
  state.answers[key] = val;
  render();
}

function goNext() {
  var step = getStep();
  if (!state.answers[step.key] && state.answers[step.key] !== 0) return;
  advance();
  render();
}

function goBack() {
  retreat();
  render();
}

// ── SIZE CONTEXT ROW ─────────────────────────────────────────────
function buildSizeRow(school, pos) {
  if (!pos) return "";
  var sz = school.size && school.size[pos];
  var bk = BENCH[pos];
  if (!sz || !bk) return "";

  var parts = [];

  if (sz.h !== null) {
    var schoolHt = inFt(sz.h);
    var benchHt  = inFt(bk.h);
    var diff = sz.h - bk.h;
    var diffStr = diff === 0 ? "avg" : (diff > 0 ? "+" : "") + diff.toFixed(1) + '"';
    parts.push("<strong>" + schoolHt + "</strong> avg height <span class='size-vs'>(" + diffStr + " vs. 8-school avg " + benchHt + ")</span>");
  }

  if (sz.w !== null) {
    var schoolWt = Math.round(sz.w) + " lbs";
    var benchWt  = Math.round(bk.w) + " lbs";
    var diffW = Math.round(sz.w - bk.w);
    var diffWStr = diffW === 0 ? "avg" : (diffW > 0 ? "+" : "") + diffW + " lbs";
    parts.push("<strong>" + schoolWt + "</strong> avg weight <span class='size-vs'>(" + diffWStr + " vs. " + benchWt + ")</span>");
  }

  if (parts.length === 0) return "";

  var posLabel = {C:"Catchers",CI:"Corner INF",MI:"Middle INF",OF:"Outfielders",P:"Pitchers",UTL:"UTL players"}[pos] || pos;
  return "<div class='size-row'>" + posLabel + " here: " + parts.join(" &middot; ") + "</div>";
}

// ── FIT NARRATIVE ────────────────────────────────────────────────
function buildFitNarrative(s, result, answers, pos) {
  var sentences = [];
  var posLabels = {C:"catchers",CI:"corner infielders",MI:"middle infielders",OF:"outfielders",P:"pitchers",UTL:"utility players"};

  // 1. Position depth / opportunity
  if (pos === "P") {
    var hand = (answers.style && answers.style.indexOf("lhp_") === 0) ? "LHP" : "RHP";
    var handCount = (hand === "LHP") ? s.lhp : s.rhp;
    var opp = (hand === "LHP" && s.lhpPct < 0.20) ? "Left-handers are scarce here — a real opportunity for a LHP." :
              (hand === "LHP" && s.lhpPct > 0.35) ? "Already LHP-heavy — you'd compete for a spot in a crowded rotation." :
              (hand === "RHP" && s.lhpPct > 0.30) ? "The staff leans left-handed, so a RHP could fill a need." :
              "";
    sentences.push("There are " + handCount + " " + hand + "s among " + s.pitchers + " total pitchers." +
                   (opp ? " " + opp : ""));
  } else {
    var n = s.pos[pos] || 0;
    var lbl = posLabels[pos] || pos;
    if (n <= 2)      sentences.push("Only " + n + " " + lbl + " on the roster — that's a genuine opportunity for playing time.");
    else if (n <= 5) sentences.push("There are " + n + " " + lbl + " on roster — competitive for a spot but not a wall of depth.");
    else             sentences.push("Depth is significant at your position (" + n + " " + lbl + ") — you'd be competing hard to crack the lineup.");
  }

  // 2. Style / tag match quality
  var score = result.score;
  if (score >= 5)      sentences.push("Strong stylistic fit — " + score + " of your profile traits match what this program values.");
  else if (score >= 3) sentences.push("Solid overlap on " + score + " key traits with this program's identity.");
  else if (score >= 1) sentences.push(score + " trait" + (score > 1 ? "s" : "") + " align here — less of a natural fit, but worth exploring.");
  else                 sentences.push("Limited overlap with your profile — consider this a reach if you're set on your style.");

  // 3. Handedness fit for hitters
  if (pos !== "P" && answers.style) {
    var st = answers.style;
    var isLefty = (st.indexOf("L_") === 0 || st.indexOf("S_") === 0);
    if (isLefty && s.leftyBat !== null) {
      if (s.leftyBat < 0.20) sentences.push("Left-handed bats are rare here (" + pct(s.leftyBat) + " of lineup) — you'd stand out.");
      else if (s.leftyBat > 0.40) sentences.push("Lineups skew left-handed (" + pct(s.leftyBat) + ") — good fit for a lefty bat.");
    }
  }

  // 3. Academic fit (show early if meaningful gap or opportunity)
  if (answers.academic) {
    var acadLevel = s.acad.level;
    var playerGpa = answers.academic;
    if (acadLevel === "selective" && (playerGpa === "standard" || playerGpa === "lower")) {
      sentences.push("Academic bar is higher here (avg GPA " + s.acad.gpa + ", ACT " + s.acad.act + ") — coach advocacy is often key to admission.");
    } else if (acadLevel === "accessible" && playerGpa === "lower") {
      sentences.push("Open admissions environment (" + s.acad.accept + " accept rate) — academics won't be a barrier here.");
    }
  }

  // 4. Culture fit
  if (answers.culture === "homegrown" && s.xfer === 0) {
    sentences.push("Zero transfers on roster — exactly the homegrown culture you said you want.");
  } else if (answers.culture === "transfer" && s.xfer > 0.15) {
    sentences.push("Transfer-active program (" + pct(s.xfer) + " of roster) — aligns with the culture you're looking for.");
  } else if (answers.culture === "homegrown" && s.xfer > 0.15) {
    sentences.push("Note: this roster carries " + pct(s.xfer) + " transfers — less of the homegrown feel you described.");
  }

  return sentences.slice(0, 3).join(" ");
}

// ── ACADEMIC FIT NOTE ────────────────────────────────────────────
function buildAcadFit(s, answers) {
  var gpa = answers.academic;
  if (!gpa) return "<em>Answer the GPA question to see your academic fit here.</em>";
  var level = s.acad.level;
  if (level === "selective") {
    if (gpa === "high")
      return "<strong>Strong academic fit.</strong> Your GPA aligns well with their typical admitted student (avg " + s.acad.gpa + " GPA, ACT " + s.acad.act + ").";
    if (gpa === "mid")
      return "<strong>Borderline fit.</strong> Their avg admitted GPA is " + s.acad.gpa + " with ACT " + s.acad.act + ". You're close — a coach\u2019s early support matters here.";
    return "<strong>Academic stretch.</strong> Admitted students average " + s.acad.gpa + " GPA and ACT " + s.acad.act + ". Coach advocacy and a strong athletic case are essential.";
  }
  if (level === "moderate") {
    if (gpa === "high" || gpa === "mid")
      return "<strong>Comfortable academic fit.</strong> Your GPA is well within their typical range (avg " + s.acad.gpa + ", ACT " + s.acad.act + ").";
    if (gpa === "standard")
      return "<strong>Solid fit.</strong> You meet their typical standard (avg " + s.acad.gpa + " GPA). No academic concerns here.";
    return "<strong>May need support.</strong> Their avg is " + s.acad.gpa + " GPA \u2014 talk to the coach early about academic pathways.";
  }
  // accessible
  if (gpa === "lower")
    return "<strong>Accessible program.</strong> With a " + s.acad.accept + " acceptance rate, this school has an open admissions philosophy \u2014 academics are not a barrier.";
  return "<strong>Comfortable academic fit.</strong> Broad acceptance (" + s.acad.accept + " rate) \u2014 you\u2019re well within their typical admitted range.";
}

// ── RESULTS ──────────────────────────────────────────────────────
function showResults() {
  document.getElementById("pf").style.width = "100%";
  var results = runMatch(state.answers);
  var pos = state.answers.position;
  var topScore = results.length ? results[0].score : 0;

  var cards = "";
  for (var i=0; i<results.length; i++) {
    var r = results[i];
    var s = r.school;
    var isTop = (i === 0 && r.score === topScore && r.score > 0);

    // Matched tags
    var matchHtml = "";
    for (var j=0; j<r.matched.length; j++) {
      matchHtml += "<span class='tag tag-match'>" + tl(r.matched[j]) + "</span>";
    }

    // Info chips
    var infoHtml = "";
    infoHtml += "<span class='tag tag-info'>" + pct(s.lhpPct) + " LHP</span>";
    if (s.leftyBat !== null)
      infoHtml += "<span class='tag tag-info'>" + pct(s.leftyBat) + " lefty bats</span>";
    if (s.xfer > 0)
      infoHtml += "<span class='tag tag-opportunity'>" + pct(s.xfer) + " transfers</span>";

    // Depth row
    var depthHtml = "";
    if (pos !== "P") {
      var n = s.pos[pos] || 0;
      depthHtml = "<div class='depth-chip'><strong>" + n + "</strong> " + pos + " on roster</div>";
    } else {
      depthHtml = "<div class='depth-chip'><strong>" + s.pitchers + "</strong> pitchers total</div>" +
                  "<div class='depth-chip'><strong>" + s.lhp + "</strong> LHP &middot; <strong>" + s.rhp + "</strong> RHP</div>";
    }

    cards += "<div class='school-card" + (isTop ? " top-match" : "") + "'>" +
      (isTop ? "<div class='top-banner'>&#11088; Best match</div>" : "") +
      "<div class='school-card-header'>" +
        "<div><div class='school-name'>" + s.school + "</div>" +
        "<div class='school-meta'>" + s.city + " &middot; " + s.conf + "</div></div>" +
        "<div class='match-score'><div class='num'>" + r.score + "</div><div class='lbl'>match pts</div></div>" +
      "</div>" +
      "<div class='school-stats'>" +
        "<div class='stat-row'>" +
          "<div class='stat-row-label'>Hitting</div>" +
          "<div class='stat-cell'><div class='stat-val'>." + Math.round(s.avg * 1000) + "</div><div class='stat-lbl'>AVG</div></div>" +
          "<div class='stat-cell'><div class='stat-val'>" + s.hr + "</div><div class='stat-lbl'>HR</div></div>" +
          "<div class='stat-cell'><div class='stat-val'>" + s.sb + "</div><div class='stat-lbl'>SB</div></div>" +
        "</div>" +
        "<div class='stat-row'>" +
          "<div class='stat-row-label'>Pitching</div>" +
          "<div class='stat-cell'><div class='stat-val'>" + s.era.toFixed(2) + "</div><div class='stat-lbl'>ERA</div></div>" +
          "<div class='stat-cell'><div class='stat-val'>" + s.so + "</div><div class='stat-lbl'>Staff K</div></div>" +
          "<div class='stat-cell'><div class='stat-val'>" + s.bb + "</div><div class='stat-lbl'>Staff BB</div></div>" +
        "</div>" +
      "</div>" +
      "<div class='fit-section'><div class='fit-label'>How do I fit?</div><div class='fit-text'>" + buildFitNarrative(s, r, state.answers, pos) + "</div></div>" +
      "<details class='card-details'><summary>&#127891; Academics</summary>" +
        "<div class='acad-grid'>" +
          "<div class='acad-cell'><div class='acad-val'>" + s.acad.gpa + "</div><div class='acad-lbl'>Avg GPA</div></div>" +
          "<div class='acad-cell'><div class='acad-val'>" + s.acad.act + "</div><div class='acad-lbl'>ACT mid-50%</div></div>" +
          "<div class='acad-cell'><div class='acad-val'>" + s.acad.accept + "</div><div class='acad-lbl'>Accept rate</div></div>" +
        "</div>" +
        "<div class='acad-fit'>" + buildAcadFit(s, state.answers) + "</div>" +
      "</details>" +
      "<details class='card-details'><summary>More details</summary>" +
      buildSizeRow(s, pos) +
      "<div class='school-tags'>" + matchHtml + infoHtml + "</div>" +
      "<div class='depth-row'>" + depthHtml + "</div>" +
      "</details>" +
      "<div class='coach-row'>" +
        "<div class='coach-info'>" +
          "<div class='coach-name'>" + s.coach.name + "</div>" +
          "<div class='coach-sub'>" + s.coach.title + "</div>" +
        "</div>" +
        (s.coach.email
          ? "<a href='mailto:" + s.coach.email + "' class='coach-contact'>Email coach &#8594;</a>"
          : "<a href='" + s.coach.coachUrl + "' target='_blank' class='coach-contact'>Contact &#8594;</a>") +
      "</div>" +
      "<div class='school-footer'>" +
        "<a href='" + s.url + "' target='_blank' class='roster-link'>View roster &#8594;</a>" +
        "<span class='drive-badge'>" + s.drive + " min from Naperville</span>" +
      "</div></div>";
  }

  var summary = buildSummary(state.answers);

  document.getElementById("app").innerHTML =
    "<div class='results-header'><h2>Your Matches</h2><p>" + summary + "</p></div>" +
    cards +
    "<div class='action-row'><button class='btn-restart' onclick='restart()'>&#8635; Start over</button><button class='btn-share' onclick='copyLink(this)'>&#128279; Share results</button></div>" +
    "<p class='disclaimer'>Roster data scraped March 2026 &middot; Stats from 2025 season &middot; 8 CCIW/NACC programs within 50 min of Naperville<br>Academic stats from publicly reported admission data &middot; Always contact coaches directly.</p>";
}

function buildSummary(a) {
  var posL = {C:"Catcher",CI:"Corner INF",MI:"Middle INF",OF:"Outfield",P:"Pitcher",UTL:"Multi-pos"};
  var spdL = {very_fast:"fast runner",average_speed:"avg speed",not_a_baserunner:"power bat"};
  var styL = {lhp_strikeout:"LHP strikeout",lhp_contact:"LHP contact",
              rhp_strikeout:"RHP strikeout",rhp_contact:"RHP contact",
              L_power:"LH power",L_contact:"LH contact",R_power:"RH power",R_contact:"RH contact",S_any:"Switch"};
  var parts = [];
  if (a.position) parts.push(posL[a.position] || a.position);
  if (a.style)    parts.push(styL[a.style] || a.style);
  if (a.speed)    parts.push(spdL[a.speed] || a.speed);
  if (a.drive)    parts.push(a.drive === "0" ? "city only" : "max " + a.drive + " min");
  return parts.join(" &middot; ");
}

function restart() {
  state = { stepIdx:0, answers:{} };
  // Clear URL params without reloading
  if (window.history && window.history.replaceState) {
    window.history.replaceState(null, "", window.location.pathname);
  }
  render();
}

// ── SHARE LINK ───────────────────────────────────────────────────
function copyLink(btn) {
  var a = state.answers;
  var params = [];
  var keys = ["position","style","speed","drive","culture"];
  for (var i=0; i<keys.length; i++) {
    if (a[keys[i]] !== undefined && a[keys[i]] !== null) {
      params.push(encodeURIComponent(keys[i]) + "=" + encodeURIComponent(a[keys[i]]));
    }
  }
  var url = window.location.pathname + (params.length ? "?" + params.join("&") : "");
  var full = window.location.origin + url;

  // Copy to clipboard
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(full).then(function() { flashShare(btn); });
  } else {
    // Fallback for browsers without clipboard API
    var ta = document.createElement("textarea");
    ta.value = full;
    ta.style.position = "fixed"; ta.style.top = "-9999px";
    document.body.appendChild(ta);
    ta.select();
    try { document.execCommand("copy"); } catch(e) {}
    document.body.removeChild(ta);
    flashShare(btn);
  }
}

function flashShare(btn) {
  btn.textContent = "Copied!";
  btn.classList.add("copied");
  setTimeout(function() {
    btn.innerHTML = "&#128279; Share results";
    btn.classList.remove("copied");
  }, 2200);
}

// ── INIT ─────────────────────────────────────────────────────────
// Check for shared link params
(function() {
  var search = window.location.search;
  if (search && search.indexOf("position=") > -1) {
    var pairs = search.slice(1).split("&");
    var loaded = {};
    for (var i=0; i<pairs.length; i++) {
      var kv = pairs[i].split("=");
      if (kv.length === 2) {
        loaded[decodeURIComponent(kv[0])] = decodeURIComponent(kv[1]);
      }
    }
    if (loaded.position) {
      state.answers = loaded;
      state.stepIdx = STEPS.length; // jump straight to results
      showResults();
      return;
    }
  }
  render();
})();
</script>
</body>
</html>
