<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chicago-Area D3 Baseball Finder</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --navy: #1a2744; --navy-light: #243360; --red: #c8102e;
    --gold: #f5a623; --gray-50: #f8f9fa; --gray-100: #f0f2f5;
    --gray-200: #e4e8ed; --gray-400: #9aa5b4; --gray-600: #4a5568;
    --gray-800: #1a202c; --green: #276749; --green-light: #e6f4ec;
    --blue-light: #ebf4ff; --radius: 12px;
    --shadow: 0 4px 24px rgba(0,0,0,.10); --shadow-sm: 0 2px 8px rgba(0,0,0,.07);
  }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: var(--gray-100); color: var(--gray-800); min-height: 100vh; }
  .header { background: var(--navy); color: #fff; padding: 20px 24px 18px; text-align: center; }
  .header h1 { font-size: 1.45rem; font-weight: 700; letter-spacing: -.3px; }
  .header p { font-size: .85rem; color: rgba(255,255,255,.65); margin-top: 4px; }
  .badge { display: inline-block; background: var(--red); color: #fff; font-size: .7rem; font-weight: 700; padding: 2px 8px; border-radius: 99px; letter-spacing: .5px; margin-bottom: 8px; text-transform: uppercase; }
  .progress-bar { background: var(--navy-light); height: 4px; }
  .progress-fill { height: 100%; background: var(--gold); transition: width .35s ease; }
  .container { max-width: 640px; margin: 0 auto; padding: 20px 16px 40px; }
  .step-card { background: #fff; border-radius: var(--radius); box-shadow: var(--shadow); padding: 28px 24px; animation: fadeIn .25s ease; }
  @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:none; } }
  .step-label { font-size: .75rem; font-weight: 600; color: var(--red); text-transform: uppercase; letter-spacing: .8px; margin-bottom: 8px; }
  .step-question { font-size: 1.2rem; font-weight: 700; color: var(--navy); margin-bottom: 6px; line-height: 1.35; }
  .step-hint { font-size: .82rem; color: var(--gray-400); margin-bottom: 20px; }
  .options { display: grid; gap: 10px; }
  .options.two-col { grid-template-columns: 1fr 1fr; }
  .option-btn { display: flex; align-items: center; gap: 12px; padding: 14px 16px; border: 2px solid var(--gray-200); border-radius: 10px; background: #fff; cursor: pointer; text-align: left; transition: all .15s ease; font-size: .93rem; font-weight: 500; color: var(--gray-800); width: 100%; }
  .option-btn:hover { border-color: var(--navy); background: var(--blue-light); }
  .option-btn.selected { border-color: var(--navy); background: var(--navy); color: #fff; }
  .option-btn .icon { font-size: 1.3rem; flex-shrink: 0; width: 28px; text-align: center; }
  .option-btn .label { flex: 1; }
  .option-btn .sublabel { font-size: .76rem; opacity: .65; margin-top: 1px; font-weight: 400; }
  .nav-row { display: flex; gap: 10px; margin-top: 24px; }
  .btn { flex: 1; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: .95rem; font-weight: 600; transition: all .15s ease; }
  .btn-back { background: var(--gray-100); color: var(--gray-600); flex: 0 0 auto; width: 90px; }
  .btn-back:hover { background: var(--gray-200); }
  .btn-next { background: var(--navy); color: #fff; }
  .btn-next:hover { background: var(--navy-light); }
  .btn-next:disabled { background: var(--gray-200); color: var(--gray-400); cursor: not-allowed; }
  .results-header { text-align: center; margin-bottom: 20px; }
  .results-header h2 { font-size: 1.4rem; font-weight: 700; color: var(--navy); }
  .results-header p { font-size: .85rem; color: var(--gray-400); margin-top: 4px; }
  .school-card { background: #fff; border-radius: var(--radius); box-shadow: var(--shadow-sm); margin-bottom: 14px; overflow: hidden; border: 2px solid transparent; }
  .school-card.top-match { border-color: var(--navy); }
  .top-banner { background: var(--navy); color: #fff; font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; padding: 5px 18px; }
  .school-card-header { padding: 16px 18px 12px; display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
  .school-name { font-size: 1.05rem; font-weight: 700; color: var(--navy); }
  .school-meta { font-size: .78rem; color: var(--gray-400); margin-top: 3px; }
  .match-score { flex-shrink: 0; text-align: center; background: var(--navy); color: #fff; border-radius: 8px; padding: 6px 12px; min-width: 54px; }
  .top-match .match-score { background: var(--red); }
  .match-score .num { font-size: 1.4rem; font-weight: 800; line-height: 1; }
  .match-score .lbl { font-size: .62rem; opacity: .7; text-transform: uppercase; letter-spacing: .5px; }
  .school-stats { border-top: 1px solid var(--gray-100); border-bottom: 1px solid var(--gray-100); }
  .stat-row { display: grid; grid-template-columns: 62px 1fr 1fr 1fr; align-items: stretch; }
  .stat-row + .stat-row { border-top: 1px solid var(--gray-100); background: var(--gray-50); }
  .stat-row-label { display: flex; align-items: center; justify-content: center; padding: 10px 8px; font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .7px; color: #fff; background: var(--navy); border-right: 1px solid rgba(255,255,255,.15); text-align: center; line-height: 1.3; }
  .stat-row + .stat-row .stat-row-label { background: var(--navy-light); }
  .stat-cell { padding: 10px 12px; text-align: center; border-right: 1px solid var(--gray-100); }
  .stat-cell:last-child { border-right: none; }
  .stat-val { font-size: 1.05rem; font-weight: 700; color: var(--navy); }
  .stat-lbl { font-size: .68rem; color: var(--gray-400); text-transform: uppercase; letter-spacing: .4px; margin-top: 1px; }
  /* Collapsible details section */
  .card-details { border-top: 1px solid var(--gray-100); }
  .card-details summary { list-style: none; padding: 9px 18px; font-size: .78rem; font-weight: 600; color: var(--gray-400); cursor: pointer; user-select: none; display: flex; align-items: center; gap: 6px; }
  .card-details summary::-webkit-details-marker { display: none; }
  .card-details summary::after { content: "›"; font-size: 1rem; transition: transform .2s; margin-left: auto; }
  .card-details[open] summary::after { transform: rotate(90deg); }
  .card-details summary:hover { color: var(--navy); }
  .size-row { padding: 6px 18px 10px; font-size: .78rem; color: var(--gray-600); }
  .size-row strong { color: var(--navy); }
  .size-vs { color: var(--gray-400); margin-left: 4px; }
  .school-tags { padding: 12px 18px; display: flex; flex-wrap: wrap; gap: 6px; }
  .tag { font-size: .7rem; font-weight: 600; padding: 3px 9px; border-radius: 99px; }
  .tag-match { background: var(--navy); color: #fff; }
  .tag-info { background: var(--gray-100); color: var(--gray-600); }
  .tag-opportunity { background: var(--green-light); color: var(--green); }
  .tag-caution { background: #fff3e0; color: #e65100; }
  .depth-row { padding: 0 18px 12px; display: flex; gap: 8px; flex-wrap: wrap; }
  .depth-chip { font-size: .75rem; color: var(--gray-600); background: var(--gray-50); border: 1px solid var(--gray-200); padding: 4px 10px; border-radius: 6px; }
  .depth-chip strong { color: var(--navy); }
  .school-footer { padding: 10px 18px 14px; display: flex; align-items: center; justify-content: space-between; }
  .roster-link { font-size: .8rem; color: var(--red); text-decoration: none; font-weight: 600; }
  .roster-link:hover { text-decoration: underline; }
  .drive-badge { font-size: .75rem; color: var(--gray-400); }
  /* Bottom action row */
  .action-row { display: flex; gap: 10px; justify-content: center; margin-top: 16px; flex-wrap: wrap; }
  .btn-restart { background: none; border: 2px solid var(--gray-200); color: var(--gray-600); padding: 10px 22px; border-radius: 10px; cursor: pointer; font-size: .88rem; font-weight: 600; transition: all .15s; }
  .btn-restart:hover { border-color: var(--navy); color: var(--navy); }
  .btn-share { background: var(--navy); color: #fff; border: 2px solid var(--navy); padding: 10px 22px; border-radius: 10px; cursor: pointer; font-size: .88rem; font-weight: 600; transition: all .15s; }
  .btn-share:hover { background: var(--navy-light); border-color: var(--navy-light); }
  .btn-share.copied { background: var(--green); border-color: var(--green); }
  /* How do I fit */
  .fit-section { padding: 10px 18px 12px; border-top: 1px solid var(--gray-100); }
  .fit-label { font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .6px; color: var(--red); margin-bottom: 5px; }
  .fit-text { font-size: .82rem; color: var(--gray-600); line-height: 1.55; }
  /* Coach row */
  .coach-row { padding: 10px 18px 12px; border-top: 1px solid var(--gray-100); display: flex; align-items: center; gap: 10px; }
  .coach-info { flex: 1; min-width: 0; }
  .coach-name { font-size: .83rem; font-weight: 600; color: var(--navy); }
  .coach-sub { font-size: .72rem; color: var(--gray-400); margin-top: 1px; }
  .coach-contact { font-size: .78rem; color: var(--red); text-decoration: none; font-weight: 600; white-space: nowrap; flex-shrink: 0; }
  .coach-contact:hover { text-decoration: underline; }
  /* Academic collapsible */
  .acad-grid { display: grid; grid-template-columns: repeat(3,1fr); padding: 8px 18px 2px; gap: 4px; }
  .acad-cell { text-align: center; padding: 8px 4px; }
  .acad-val { font-size: 1rem; font-weight: 700; color: var(--navy); }
  .acad-lbl { font-size: .66rem; color: var(--gray-400); text-transform: uppercase; letter-spacing: .4px; margin-top: 2px; }
  .acad-fit { padding: 4px 18px 12px; font-size: .8rem; color: var(--gray-600); line-height: 1.55; }
  .acad-fit strong { color: var(--navy); }
  .acad-fit em { color: var(--gray-400); }
  .disclaimer { font-size: .73rem; color: var(--gray-400); text-align: center; margin-top: 20px; line-height: 1.5; }
  /* ── MOBILE ── */
  @media (max-width: 600px) {
    .options.two-col { grid-template-columns: 1fr; }
    .container { padding: 14px 12px 40px; }
    .step-card { padding: 20px 16px; }
    .step-question { font-size: 1.08rem; }
    .option-btn { min-height: 54px; padding: 12px 14px; font-size: .9rem; }
    .btn { min-height: 48px; font-size: .92rem; }
    .btn-back { width: 76px; }
    .header h1 { font-size: 1.25rem; }
    .header p { font-size: .8rem; }
    .school-card-header { padding: 13px 14px 10px; gap: 8px; }
    .school-name { font-size: .97rem; }
    .school-meta { font-size: .74rem; }
    .match-score { min-width: 46px; padding: 5px 9px; }
    .match-score .num { font-size: 1.25rem; }
    .stat-row { grid-template-columns: 52px 1fr 1fr 1fr; }
    .stat-row-label { font-size: .55rem; padding: 8px 4px; }
    .stat-cell { padding: 8px 6px; }
    .stat-val { font-size: .95rem; }
    .stat-lbl { font-size: .63rem; }
    .fit-section { padding: 9px 14px 10px; }
    .fit-text { font-size: .8rem; }
    .card-details summary { padding: 9px 14px; font-size: .76rem; }
    .size-row { padding: 6px 14px 10px; font-size: .75rem; }
    .school-tags { padding: 10px 14px; gap: 5px; }
    .tag { font-size: .67rem; padding: 3px 8px; }
    .depth-row { padding: 0 14px 10px; }
    .acad-grid { padding: 8px 14px 2px; }
    .acad-fit { padding: 4px 14px 10px; font-size: .77rem; }
    .coach-row { padding: 9px 14px 10px; }
    .school-footer { padding: 9px 14px 12px; }
    .roster-link { font-size: .78rem; }
    .drive-badge { font-size: .72rem; }
    .action-row { flex-direction: column; gap: 8px; }
    .btn-restart, .btn-share { width: 100%; padding: 13px 22px; }
    .results-header h2 { font-size: 1.2rem; }
  }
</style>
</head>
<body>

<div class="header">
  <div class="badge">&#x26BE; D3 Baseball</div>
  <h1>Chicago-Area School Finder</h1>
  <p>CCIW &amp; NACC programs &middot; Naperville-based &middot; Roster data 2026</p>
